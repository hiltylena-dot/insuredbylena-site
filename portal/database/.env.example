# Copy to .env and fill values.

# Publisher mode: buffer_graphql, webhook, or mock.
# Leave blank to auto-select:
# - buffer_graphql if BUFFER_API_KEY exists
# - webhook if CONTENT_SCHEDULER_WEBHOOK_URL exists
# - mock otherwise
CONTENT_PUBLISHER_MODE=

# Direct Buffer API mode (recommended)
BUFFER_API_KEY=
BUFFER_ORGANIZATION_ID=
BUFFER_CHANNEL_ID_INSTAGRAM=
BUFFER_CHANNEL_ID_FACEBOOK=
BUFFER_CHANNEL_ID_TIKTOK=
BUFFER_API_BASE_URL=https://api.buffer.com

# Legacy webhook fallback
CONTENT_SCHEDULER_WEBHOOK_URL=

# Optional bearer token if your webhook expects auth.
CONTENT_SCHEDULER_API_KEY=

# Label shown in publish jobs table.
CONTENT_SCHEDULER_NAME=buffer_postiz

# Google Imagen / Drive pipeline
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_IMAGEN_MODEL=imagen-4.0-fast-generate-001
PUBLIC_MEDIA_BASE_URL=

# Supabase migration target
# Keep the service role key server-side only. Never expose it in browser code.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_DB_PASSWORD=
SUPABASE_DB_HOST=
SUPABASE_DB_PORT=5432
SUPABASE_DB_NAME=postgres
SUPABASE_DB_USER=postgres
GOOGLE_CALENDAR_WEB_APP_URL=
GOOGLE_CALENDAR_SECRET=replace-this-with-a-secret-you-choose
